+//! Per-stream keyed-append durable journal (`<data file>.keys`).
+//!
+//! `StreamState::key_dir` is the routing-key → `(offset, len)` span index that
+//! backs `?key=` keyed catch-up reads (see `handlers::handle_keyed_catchup`),
+//! plus the zero-copy fork references that let a branch key inherit a source
+//! key's prefix without copying its spans (see `store::KeyDir::resolved_spans`).
+//! The routing key lives only in the `Stream-Key` request header — it is never
+//! part of the WAL record or the wire bytes — and a fork reference lives only in
+//! the fork-create request headers, so neither has anywhere else to be
+//! reconstructed from after a restart. This module is that missing durable copy.
+//!
+//! # On-disk layout
+//!
+//! One flat, append-only file per stream, created lazily on the stream's FIRST
+//! keyed append or keyed fork (a stream that never uses `Stream-Key` never gets
+//! a `.keys` file — see `KeyDir::empty`). Each durable event appends one framed
+//! record with a uniform outer frame so replay can advance past any record kind
+//! without decoding its body:
+//!
+//! ```text
+//! u32  body_len          // length of the body that follows
+//! u32  crc32c(body)      // over the body bytes
+//! [body_len bytes] body
+//! ```
+//!
+//! The body's first byte is a kind tag:
+//!
+//! ```text
+//! kind 0  (span):  0u8 | offset:u64 | len:u64 | key_len:u32 | key_bytes
+//! kind 1  (fork):  1u8 | cut:u64    | dest_len:u32 | src_len:u32 | dest_bytes | src_bytes
+//! ```
+//!
+//! Fixed outer header is 8 bytes ([`HEADER_LEN`]). All multi-byte integers are
+//! little-endian.
+//!
+//! **Torn-tail detection** mirrors `wal::codec`: replay ([`replay`]) walks
+//! records from offset 0 and stops at the first one whose body CRC fails, whose
+//! `body_len` runs past EOF, or whose header is all-zero — that is the clean end
+//! of the durable log, not corruption (same philosophy as the WAL's
+//! header-CRC-doubles-as-torn-detector design; see `wal::codec` module docs).
+//! On recovery ([`KeyJournal::recover`]) any bytes past that point are truncated
+//! before the file is reopened for further appends — otherwise a later append
+//! would land after an unreachable gap of garbage that a future replay would
+//! stop at before ever reaching it (the WAL's C1 torn-tail reasoning, applied
+//! here at whole-journal-file granularity instead of a reconciled byte tail).
+//!
+//! # Durability guarantee
+//!
+//! **Durable at ack — no crash-tail window.** `StreamState::record_keyed_append`
+//! and `StreamState::fork_key` fsync the journal ([`KeyJournal::flush_if_dirty`])
+//! before the keyed append / fork is acked to the client, so a hard crash
+//! immediately after the ack still rebuilds that routing on restart. A keyed
+//! append is therefore exactly as durably indexed as its data is durable in the
+//! WAL/log, and a fork reference is durable before its 201 — there is no
+//! acked-but-unindexed gap. This costs one journal fsync per event on top of the
+//! WAL group-commit fsync; the append path is already serialized per stream by
+//! the appender lock, so it adds no new write contention (a concurrent keyed
+//! *read* on the same stream may briefly wait on the fsync).
+//!
+//! [`flush_if_dirty`](KeyJournal::flush_if_dirty) is also still called from
+//! `store::write_meta_sync` as a backstop (a no-op once the per-event fsync has
+//! cleared the dirty flag). A journal write that *fails* (open/write error) is
+//! best-effort per [`append`](KeyJournal::append) — it leaves that record
+//! memory-only for the run and never fails the append itself; the underlying
+//! data is never at risk (it is durable in the WAL/log independent of this
+//! journal). Perf note: batching these fsyncs into the WAL group commit would
+//! amortize the per-append cost — a future optimization, not a correctness need.
+
+use std::collections::HashMap;
+use std::fs::{File, OpenOptions};
+use std::path::{Path, PathBuf};
+
+use crate::store::barrier_fsync;
+
+/// Fixed-size outer frame header: `body_len(4) + crc32c(4)`.
+pub const HEADER_LEN: usize = 4 + 4;
+
+/// Sanity cap on a decoded `body_len`. Routing keys are short strings in
+/// practice, so a legitimate record body is small; a `body_len` this large is
+/// essentially certain to be a torn/garbled header rather than a real record, so
+/// treat it as torn rather than attempting a multi-KB slice on the strength of
+/// an unverified length.
+const MAX_BODY_LEN: usize = 1 << 16;
+
+/// Body kind tags (first body byte).
+const KIND_SPAN: u8 = 0;
+const KIND_FORK: u8 = 1;
+
+/// One rebuilt directory event. `replay` folds these into the span map and the
+/// fork map.
+enum Event {
+    Span { key: String, offset: u64, len: u64 },
+    Fork { dest: String, src: String, cut: u64 },
+}
+
+/// Result of decoding one framed record at a byte offset. See the module docs
+/// for `Torn` vs `Incomplete`; both end replay the same way (the durable log
+/// ends before this point) — they are kept distinct only for diagnosability.
+enum Decoded {
+    Record { event: Event, total: usize },
+    /// Not enough bytes for a header/body, or an all-zero header.
+    Incomplete,
+    /// A header is present but its body CRC is bad, or the body doesn't decode
+    /// (unknown kind, bad UTF-8, or a short body) — should be unreachable once
+    /// the CRC passes, kept as a defensive last check.
+    Torn,
+}
+
+/// Encode one framed record (outer frame + body) ready to append.
+fn frame(body: &[u8]) -> Vec<u8> {
+    let crc = crc32c::crc32c(body);
+    let mut out = Vec::with_capacity(HEADER_LEN + body.len());
+    out.extend_from_slice(&(body.len() as u32).to_le_bytes());
+    out.extend_from_slice(&crc.to_le_bytes());
+    out.extend_from_slice(body);
+    out
+}
+
+/// Encode a span record.
+fn encode_span(key: &str, offset: u64, len: u64) -> Vec<u8> {
+    let kb = key.as_bytes();
+    let mut body = Vec::with_capacity(1 + 8 + 8 + 4 + kb.len());
+    body.push(KIND_SPAN);
+    body.extend_from_slice(&offset.to_le_bytes());
+    body.extend_from_slice(&len.to_le_bytes());
+    body.extend_from_slice(&(kb.len() as u32).to_le_bytes());
+    body.extend_from_slice(kb);
+    frame(&body)
+}
+
+/// Encode a fork-reference record.
+fn encode_fork(dest: &str, src: &str, cut: u64) -> Vec<u8> {
+    let db = dest.as_bytes();
+    let sb = src.as_bytes();
+    let mut body = Vec::with_capacity(1 + 8 + 4 + 4 + db.len() + sb.len());
+    body.push(KIND_FORK);
+    body.extend_from_slice(&cut.to_le_bytes());
+    body.extend_from_slice(&(db.len() as u32).to_le_bytes());
+    body.extend_from_slice(&(sb.len() as u32).to_le_bytes());
+    body.extend_from_slice(db);
+    body.extend_from_slice(sb);
+    frame(&body)
+}
+
+/// Decode the body bytes into an `Event`, or `None` if malformed.
+fn decode_body(body: &[u8]) -> Option<Event> {
+    let (&kind, rest) = body.split_first()?;
+    match kind {
+        KIND_SPAN => {
+            if rest.len() < 8 + 8 + 4 {
+                return None;
+            }
+            let offset = u64::from_le_bytes(rest[0..8].try_into().ok()?);
+            let len = u64::from_le_bytes(rest[8..16].try_into().ok()?);
+            let key_len = u32::from_le_bytes(rest[16..20].try_into().ok()?) as usize;
+            let key_bytes = rest.get(20..20 + key_len)?;
+            let key = std::str::from_utf8(key_bytes).ok()?.to_string();
+            Some(Event::Span { key, offset, len })
+        }
+        KIND_FORK => {
+            if rest.len() < 8 + 4 + 4 {
+                return None;
+            }
+            let cut = u64::from_le_bytes(rest[0..8].try_into().ok()?);
+            let dest_len = u32::from_le_bytes(rest[8..12].try_into().ok()?) as usize;
+            let src_len = u32::from_le_bytes(rest[12..16].try_into().ok()?) as usize;
+            let dest_bytes = rest.get(16..16 + dest_len)?;
+            let src_bytes = rest.get(16 + dest_len..16 + dest_len + src_len)?;
+            let dest = std::str::from_utf8(dest_bytes).ok()?.to_string();
+            let src = std::str::from_utf8(src_bytes).ok()?.to_string();
+            Some(Event::Fork { dest, src, cut })
+        }
+        _ => None,
+    }
+}
+
+/// Decode the record starting at byte `off` in `buf`.
+fn decode_at(buf: &[u8], off: usize) -> Decoded {
+    let Some(hdr) = buf.get(off..off + HEADER_LEN) else {
+        return Decoded::Incomplete;
+    };
+    // An all-zero header cannot be a legitimately-encoded record (we never emit
+    // a zero-length body), so treat it as the clean end of the log, not
+    // corruption.
+    if hdr.iter().all(|&b| b == 0) {
+        return Decoded::Incomplete;
+    }
+    let body_len = u32::from_le_bytes(hdr[0..4].try_into().unwrap()) as usize;
+    let crc = u32::from_le_bytes(hdr[4..8].try_into().unwrap());
+    if body_len == 0 || body_len > MAX_BODY_LEN {
+        return Decoded::Torn;
+    }
+    let total = HEADER_LEN + body_len;
+    let Some(body) = buf.get(off + HEADER_LEN..off + total) else {
+        return Decoded::Incomplete;
+    };
+    if crc32c::crc32c(body) != crc {
+        return Decoded::Torn;
+    }
+    match decode_body(body) {
+        Some(event) => Decoded::Record { event, total },
+        None => Decoded::Torn,
+    }
+}
+
+/// Fork references rebuilt from the journal: branch key → (source key, cut).
+type ForkMap = HashMap<String, (String, usize)>;
+
+/// Replay every complete record in `buf` from offset 0, stopping at the first
+/// torn/incomplete one. Returns the rebuilt span map (push order preserved, so
+/// per-key own spans stay in append order — see `handle_keyed_catchup`), the
+/// fork-reference map, and the byte length of the valid prefix (`buf.len()` iff
+/// there was no torn tail).
+fn replay(buf: &[u8]) -> (HashMap<String, Vec<(u64, u64)>>, ForkMap, usize) {
+    let mut map: HashMap<String, Vec<(u64, u64)>> = HashMap::new();
+    let mut forks: ForkMap = HashMap::new();
+    let mut off = 0usize;
+    while let Decoded::Record { event, total } = decode_at(buf, off) {
+        match event {
+            Event::Span { key, offset, len } => {
+                map.entry(key).or_default().push((offset, len));
+            }
+            Event::Fork { dest, src, cut } => {
+                forks.insert(dest, (src, cut as usize));
+            }
+        }
+        off += total;
+    }
+    (map, forks, off)
+}
+
+/// The `.keys` sidecar path for a stream's data file, mirroring
+/// `store::meta_path` (a raw `OsString` suffix append — never
+/// `PathBuf::with_extension`, which would mangle a data file name that itself
+/// contains a literal `.`, e.g. `s+orders.json~5`).
+pub fn key_journal_path(file_path: &Path) -> PathBuf {
+    let mut p = file_path.as_os_str().to_owned();
+    p.push(".keys");
+    PathBuf::from(p)
+}
+
+/// The durable half of a stream's keyed-read index: an append-only file handle
+/// (opened lazily) plus a dirty flag. Always constructed alongside the
+/// in-memory maps in `store::KeyDir`, which is the only thing that should call
+/// [`append`](KeyJournal::append) / [`append_fork`](KeyJournal::append_fork) (so
+/// the map mutation and the durable append stay in lockstep — see that type's
+/// docs).
+pub struct KeyJournal {
+    path: PathBuf,
+    file: Option<File>,
+    /// Set when `file` has bytes written since the last fsync.
+    dirty: bool,
+}
+
+impl KeyJournal {
+    /// A stream with no journal file yet — matches a freshly created stream
+    /// (no keyed appends so far). The file is created on the first
+    /// [`append`](KeyJournal::append) / [`append_fork`](KeyJournal::append_fork).
+    pub fn empty(file_path: &Path) -> Self {
+        KeyJournal {
+            path: key_journal_path(file_path),
+            file: None,
+            dirty: false,
+        }
+    }
+
+    /// Rebuild the in-memory index (span map + fork references) from
+    /// `<file_path>.keys` if it exists, then reopen the journal (truncating any
+    /// torn trailing record first) ready for future appends. Never fails: any
+    /// I/O error reading an existing journal degrades to an empty index for this
+    /// run — the pre-existing best-effort-across-restart contract on `key_dir`,
+    /// just narrower than before this module existed (only a read failure, not
+    /// every restart, hits it) — matching how a corrupt `.meta` sidecar is
+    /// discarded rather than aborting boot (see `store::recover`).
+    pub fn recover(file_path: &Path) -> (HashMap<String, Vec<(u64, u64)>>, ForkMap, KeyJournal) {
+        let path = key_journal_path(file_path);
+        let Ok(bytes) = std::fs::read(&path) else {
+            return (
+                HashMap::new(),
+                HashMap::new(),
+                KeyJournal { path, file: None, dirty: false },
+            );
+        };
+        let (map, forks, valid_len) = replay(&bytes);
+        if valid_len < bytes.len() {
+            // Torn trailing record from a crash mid-append: truncate to the
+            // last good boundary, fsync'd immediately (before any new append
+            // can land) so a subsequent append is never separated from replay
+            // by an unreachable gap of garbage a later restart would stop at.
+            if let Ok(f) = OpenOptions::new().write(true).open(&path) {
+                let _ = f.set_len(valid_len as u64);
+                let _ = barrier_fsync(&f);
+            }
+        }
+        let file = OpenOptions::new().append(true).open(&path).ok();
+        (map, forks, KeyJournal { path, file, dirty: false })
+    }
+
+    /// Buffered append of an already-framed record. Opens the file on the first
+    /// call for a stream that has never been keyed before. Best-effort: an
+    /// open/write failure just leaves this run's index memory-only for the
+    /// record (matches `key_dir`'s pre-existing contract), never fails the
+    /// append itself.
+    fn write_record(&mut self, rec: &[u8]) {
+        if self.file.is_none() {
+            self.file = OpenOptions::new().create(true).append(true).open(&self.path).ok();
+        }
+        let Some(file) = &self.file else { return };
+        use std::io::Write;
+        if (&*file).write_all(rec).is_ok() {
+            self.dirty = true;
+        }
+    }
+
+    /// Append one span record (no fsync — see module docs).
+    pub fn append(&mut self, key: &str, offset: u64, len: u64) {
+        let rec = encode_span(key, offset, len);
+        self.write_record(&rec);
+    }
+
+    /// Append one fork-reference record: `dest` inherits the first `cut` spans
+    /// of `src`. Same buffered, best-effort semantics as [`append`].
+    pub fn append_fork(&mut self, dest: &str, src: &str, cut: usize) {
+        let rec = encode_fork(dest, src, cut as u64);
+        self.write_record(&rec);
+    }
+
+    /// Fsync the journal iff it has unflushed bytes. Called from
+    /// `store::write_meta_sync`, piggybacking on the sidecar's existing flush
+    /// cadence instead of a dedicated per-append fsync — see the module docs
+    /// for the resulting durability guarantee.
+    pub fn flush_if_dirty(&mut self) {
+        if !self.dirty {
+            return;
+        }
+        if let Some(f) = &self.file {
+            if barrier_fsync(f).is_ok() {
+                self.dirty = false;
+            }
+        }
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn encode_decode_span_roundtrip() {
+        let rec = encode_span("orders", 100, 42);
+        match decode_at(&rec, 0) {
+            Decoded::Record { event: Event::Span { key, offset, len }, total } => {
+                assert_eq!(key, "orders");
+                assert_eq!(offset, 100);
+                assert_eq!(len, 42);
+                assert_eq!(total, rec.len());
+            }
+            _ => panic!("expected a decodable span record"),
+        }
+    }
+
+    #[test]
+    fn encode_decode_fork_roundtrip() {
+        let rec = encode_fork("forkX", "convA", 3);
+        match decode_at(&rec, 0) {
+            Decoded::Record { event: Event::Fork { dest, src, cut }, total } => {
+                assert_eq!(dest, "forkX");
+                assert_eq!(src, "convA");
+                assert_eq!(cut, 3);
+                assert_eq!(total, rec.len());
+            }
+            _ => panic!("expected a decodable fork record"),
+        }
+    }
+
+    #[test]
+    fn replay_preserves_per_key_push_order_and_forks() {
+        let mut buf = Vec::new();
+        buf.extend(encode_span("a", 0, 5));
+        buf.extend(encode_span("b", 5, 3));
+        buf.extend(encode_span("a", 8, 7));
+        buf.extend(encode_fork("fx", "a", 1));
+        let (map, forks, valid_len) = replay(&buf);
+        assert_eq!(valid_len, buf.len(), "no torn tail");
+        assert_eq!(map.get("a").unwrap(), &vec![(0, 5), (8, 7)]);
+        assert_eq!(map.get("b").unwrap(), &vec![(5, 3)]);
+        assert_eq!(forks.get("fx").unwrap(), &("a".to_string(), 1usize));
+    }
+
+    #[test]
+    fn empty_buffer_replays_empty() {
+        let (map, forks, valid_len) = replay(&[]);
+        assert!(map.is_empty());
+        assert!(forks.is_empty());
+        assert_eq!(valid_len, 0);
+    }
+
+    #[test]
+    fn torn_trailing_record_stops_replay_at_last_good_boundary() {
+        let mut buf = Vec::new();
+        buf.extend(encode_span("a", 0, 5));
+        let good_len = buf.len();
+        // A second record, torn: corrupt a crc byte in the outer header.
+        let mut torn = encode_span("b", 5, 9);
+        torn[4] ^= 0xFF;
+        buf.extend(&torn);
+        let (map, forks, valid_len) = replay(&buf);
+        assert_eq!(valid_len, good_len, "replay must stop before the torn record");
+        assert_eq!(map.len(), 1);
+        assert!(forks.is_empty());
+        assert_eq!(map.get("a").unwrap(), &vec![(0, 5)]);
+    }
+
+    #[test]
+    fn truncated_header_is_incomplete_not_a_record() {
+        let rec = encode_span("orders", 0, 1);
+        let short = &rec[..HEADER_LEN - 1];
+        assert!(matches!(decode_at(short, 0), Decoded::Incomplete));
+    }
+
+    #[test]
+    fn truncated_body_bytes_are_incomplete() {
+        let rec = encode_span("orders", 0, 1);
+        let short = &rec[..rec.len() - 1];
+        assert!(matches!(decode_at(short, 0), Decoded::Incomplete));
+    }
+
+    fn tmp_data_path(tag: &str) -> PathBuf {
+        use std::time::{SystemTime, UNIX_EPOCH};
+        let dir = std::env::temp_dir().join(format!(
+            "ds-key-journal-{tag}-{}-{}",
+            std::process::id(),
+            SystemTime::now().duration_since(UNIX_EPOCH).unwrap().as_nanos()
+        ));
+        std::fs::create_dir_all(&dir).unwrap();
+        dir.join("stream-data")
+    }
+
+    #[test]
+    fn recover_with_no_journal_file_is_empty() {
+        let data_path = tmp_data_path("none");
+        let (map, forks, mut journal) = KeyJournal::recover(&data_path);
+        assert!(map.is_empty());
+        assert!(forks.is_empty());
+        // Lazily creates the file on first append, like a fresh stream.
+        journal.append("k", 0, 1);
+        assert!(key_journal_path(&data_path).exists());
+        let _ = std::fs::remove_dir_all(data_path.parent().unwrap());
+    }
+
+    #[test]
+    fn recover_rebuilds_fork_references() {
+        let data_path = tmp_data_path("forkref");
+        let path = key_journal_path(&data_path);
+        let mut on_disk = Vec::new();
+        on_disk.extend(encode_span("convA", 0, 4));
+        on_disk.extend(encode_span("convA", 8, 4));
+        on_disk.extend(encode_fork("forkX", "convA", 1));
+        std::fs::write(&path, &on_disk).unwrap();
+
+        let (map, forks, _journal) = KeyJournal::recover(&data_path);
+        assert_eq!(map.get("convA").unwrap(), &vec![(0, 4), (8, 4)]);
+        assert_eq!(forks.get("forkX").unwrap(), &("convA".to_string(), 1usize));
+        let _ = std::fs::remove_dir_all(data_path.parent().unwrap());
+    }
+
+    #[test]
+    fn recover_truncates_torn_tail_and_replay_after_reopen_is_gap_free() {
+        let data_path = tmp_data_path("torn");
+        let path = key_journal_path(&data_path);
+        let mut on_disk = Vec::new();
+        on_disk.extend(encode_span("a", 0, 5));
+        on_disk.extend(encode_span("b", 5, 3));
+        let good_len = on_disk.len();
+        // Torn trailing bytes: a plausible-looking but truncated third record
+        // (cut mid-body so it actually tears, unlike truncating past the end
+        // which would be a no-op).
+        let mut torn = encode_span("cccccccccc", 8, 100);
+        torn.truncate(HEADER_LEN + 3);
+        on_disk.extend(&torn);
+        std::fs::write(&path, &on_disk).unwrap();
+
+        let (map, _forks, mut journal) = KeyJournal::recover(&data_path);
+        assert_eq!(map.len(), 2, "torn trailing record must not be indexed");
+        assert_eq!(
+            std::fs::metadata(&path).unwrap().len(),
+            good_len as u64,
+            "file truncated to the last good record"
+        );
+
+        // A fresh append must land right after the truncated boundary, not
+        // after the (now-removed) garbage — replaying again from scratch must
+        // see exactly the two original records plus the new one, no gap.
+        journal.append("d", 20, 4);
+        let on_disk_now = std::fs::read(&path).unwrap();
+        let (map2, _forks2, valid_len2) = replay(&on_disk_now);
+        assert_eq!(valid_len2, on_disk_now.len(), "no torn tail after the new append");
+        assert_eq!(map2.len(), 3);
+        assert_eq!(map2.get("d").unwrap(), &vec![(20, 4)]);
+
+        let _ = std::fs::remove_dir_all(data_path.parent().unwrap());
+    }
+}
