+    /// Record one durable keyed append: push into the in-memory index and
+    /// append the framed record to the durable journal as a single atomic
+    /// step under `key_dir`'s lock. Call only after the append is durable (WAL
+    /// fsync / memory-mode page-cache ack) — same visibility ordering as
+    /// `publish_durable_tail` (see `handlers::handle_append_inner`).
+    pub fn record_keyed_append(&self, key: &str, offset: u64, len: u64) {
+        let mut kd = self.key_dir.lock().unwrap_or_else(|e| e.into_inner());
+        kd.map.entry(key.to_string()).or_default().push((offset, len));
+        kd.journal.append(key, offset, len);
+        // Durable-at-ack: fsync the journal entry before this keyed append is
+        // acked to the client, so a hard crash immediately after the ack cannot
+        // lose the key's index entry (its data is already WAL-durable). Called
+        // from the append path, which is already serialized per stream by the
+        // appender lock, so this adds no new write contention; a concurrent
+        // keyed READ on the same stream may briefly wait on the fsync. The
+        // deferred `write_meta_sync` flush remains as a backstop (a no-op once
+        // this has already cleared the dirty flag).
+        kd.journal.flush_if_dirty();
+    }
+
+    /// In-stream keyed fork: record `dest_key` as a zero-copy REFERENCE to the
+    /// first `cut` spans of `src_key` — matching native durable-streams fork,
+    /// where offsets below the cut resolve against the source WITHOUT copying.
+    /// No prefix spans are duplicated into `dest_key`'s directory; instead a
+    /// `ForkRef { inherits_from: src_key, cut }` is stored, and a later
+    /// `?key=dest_key` read RESOLVES the reference (`keyed_spans` →
+    /// `KeyDir::resolved_spans` → `gather_keyed_bytes`): it splices the source
+    /// key's spans strictly before the cut — recursively, if the source is
+    /// itself a fork — ahead of `dest_key`'s own appended spans. No new stream,
+    /// no fork parent chain of streams; subsequent keyed appends under
+    /// `dest_key` extend it (their higher offsets keep the resolved directory
+    /// offset-ordered, which `handle_keyed_catchup`'s coalescing scan relies on).
+    /// This is the multiplexed one-stream-per-namespace fork: forking a
+    /// conversation KEY out of the shared stream, not a whole parent stream.
+    ///
+    /// `cut == None` inherits all of `src_key`'s spans; a `cut` past the span
+    /// count is clamped to it. The cut is SNAPSHOTTED to a concrete span count
+    /// at fork time (resolving the source now), so appends to `src_key` ABOVE
+    /// the cut never leak onto the branch — the inherited prefix is immutable.
+    /// Durable — the fork reference is journaled and fsync'd once before
+    /// returning, same guarantee as `record_keyed_append`. Returns the number
+    /// of spans inherited (the effective cut).
+    pub fn fork_key(&self, src_key: &str, dest_key: &str, cut: Option<usize>) -> usize {
+        let mut kd = self.key_dir.lock().unwrap_or_else(|e| e.into_inner());
+        let src_len = kd.resolved_spans(src_key).len();
+        let effective_cut = cut.unwrap_or(src_len).min(src_len);
+        kd.forks.insert(
+            dest_key.to_string(),
+            ForkRef {
+                inherits_from: src_key.to_string(),
+                cut: effective_cut,
+            },
+        );
+        kd.journal.append_fork(dest_key, src_key, effective_cut);
+        kd.journal.flush_if_dirty();
+        effective_cut
     }
