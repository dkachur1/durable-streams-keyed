+/// A zero-copy in-stream keyed fork reference (see `StreamState::fork_key`):
+/// `dest_key` inherits the first `cut` spans of `inherits_from`'s resolved span
+/// list. `cut` is a concrete count snapshotted at fork time, so the inherited
+/// prefix is immutable regardless of later appends to the source.
+struct ForkRef {
+    inherits_from: String,
+    cut: usize,
+}
+
+/// Guard against a pathological (or corrupt-journal) fork chain: resolution
+/// stops descending past this depth and treats the remaining source as empty
+/// rather than recursing without bound. Fork chains are shallow in practice
+/// (one branch per edit/regenerate).
+const MAX_FORK_DEPTH: usize = 4096;
+
+/// In-memory keyed-read index plus its durable journal (`key_journal.rs`), one
+/// lock (`StreamState::key_dir`) so the memory push and the durable append are
+/// a single atomic step: `handle_keyed_catchup`'s coalescing scan assumes push
+/// order == offset order, and replay after a restart must reproduce the exact
+/// order a live run saw.
+pub struct KeyDir {
+    /// Per-key OWN appended spans (a branch key stores only its appends ABOVE
+    /// the fork cut here — the inherited prefix is a reference in `forks`, not
+    /// copied).
+    map: HashMap<String, Vec<(u64, u64)>>,
+    /// Zero-copy fork references: branch key → the source key + cut it inherits
+    /// (see `ForkRef` and `resolved_spans`).
+    forks: HashMap<String, ForkRef>,
+    journal: crate::key_journal::KeyJournal,
+}
+
+impl KeyDir {
+    /// A freshly created stream: no keyed appends yet, no journal file.
+    fn empty(file_path: &std::path::Path) -> Self {
+        KeyDir {
+            map: HashMap::new(),
+            forks: HashMap::new(),
+            journal: crate::key_journal::KeyJournal::empty(file_path),
+        }
+    }
+
+    /// Rebuild from the durable journal on boot — see
+    /// `key_journal::KeyJournal::recover`.
+    fn recovered(file_path: &std::path::Path) -> Self {
+        let (map, forks, journal) = crate::key_journal::KeyJournal::recover(file_path);
+        let forks = forks
+            .into_iter()
+            .map(|(dest, (inherits_from, cut))| (dest, ForkRef { inherits_from, cut }))
+            .collect();
+        KeyDir { map, forks, journal }
+    }
+
+    /// The full ordered `(offset, len)` span list resolving under `key`: if
+    /// `key` is a fork branch, the first `cut` spans of its source's resolved
+    /// list (recursively — a fork of a fork walks the whole chain), spliced
+    /// AHEAD of `key`'s own appended spans. Inherited spans predate the branch's
+    /// own appends, so the list stays offset-ascending (the coalescing keyed
+    /// read relies on that). A non-branch key just returns its own spans.
+    fn resolved_spans(&self, key: &str) -> Vec<(u64, u64)> {
+        self.resolved_spans_bounded(key, MAX_FORK_DEPTH)
+    }
+
+    fn resolved_spans_bounded(&self, key: &str, depth: usize) -> Vec<(u64, u64)> {
+        let mut out = Vec::new();
+        if depth > 0 {
+            if let Some(f) = self.forks.get(key) {
+                let src = self.resolved_spans_bounded(&f.inherits_from, depth - 1);
+                let take = f.cut.min(src.len());
+                out.extend_from_slice(&src[..take]);
+            }
+        }
+        if let Some(own) = self.map.get(key) {
+            out.extend_from_slice(own);
+        }
+        out
+    }
+}
